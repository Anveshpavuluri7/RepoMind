# Application
APP_ENV=development
SECRET_KEY=your-secret-key-min-32-chars-change-in-prod
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://repomind:repomind@localhost:5432/repomind
DATABASE_URL_SYNC=postgresql://repomind:repomind@localhost:5432/repomind

# Redis
REDIS_URL=redis://localhost:6379/0

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-opus-4-8

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_PREFIX=repomind

# Frontend URL (for OAuth redirects and CORS)
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
